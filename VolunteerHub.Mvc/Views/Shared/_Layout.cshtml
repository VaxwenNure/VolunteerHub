<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Volunteer Hub</title>
    <meta name="viewport" content="width=device-width" />
    <style>
        body { font-family: Arial; margin: 20px; }
        nav a { margin-right: 12px; }
        .container { margin-top: 16px; }
        table { border-collapse: collapse; width: 100%; }
        th, td { border: 1px solid #ddd; padding: 8px; }
    </style>
    @RenderSection("Head", required: false)
</head>
<body>
    <nav>
        <a asp-controller="Volunteers" asp-action="Index">Volunteers</a>
        <a asp-controller="HelpTypes" asp-action="Index">Help Types</a>
        <a asp-controller="HelpRecords" asp-action="Index">Help Records</a>
        <a asp-controller="Reports" asp-action="TotalsByVolunteer">Report: By Volunteer</a>
        <a asp-controller="Reports" asp-action="TotalsByHelpType">Report: By Type</a>
        <a asp-controller="Session" asp-action="Logout" style="float:right;">Logout</a>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>
