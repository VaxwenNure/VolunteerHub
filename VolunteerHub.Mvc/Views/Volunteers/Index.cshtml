@using VolunteerHub.Data.Models
@model List<Volunteer>

<h2>Volunteers</h2>
<p class="add-button"><a asp-action="Create">Add new volunteer</a></p>

<table>
    <thead>
        <tr><th>Full name</th><th>Phone</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var v in Model)
        {
            <tr>
                <td>@v.FullName</td>
                <td>@v.Phone</td>
                <td>
                    <a asp-action="Details" asp-route-id="@v.VolunteerId">Details</a> |
                    <a asp-action="Edit" asp-route-id="@v.VolunteerId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@v.VolunteerId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
