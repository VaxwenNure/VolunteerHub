@using VolunteerHub.Data.Models
@model List<HelpType>

<h2>Help Types</h2>
<p class="add-button"><a asp-action="Create">Add new type</a></p>

@if (TempData["Error"] != null)
{
    <p style="color:red">@TempData["Error"]</p>
}

<table>
    <thead>
        <tr><th>Name</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@t.HelpTypeId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@t.HelpTypeId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
