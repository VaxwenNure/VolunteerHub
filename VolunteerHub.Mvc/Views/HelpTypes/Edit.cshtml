@using VolunteerHub.Data.Models
@model HelpType

<h2>Edit Help Type</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="HelpTypeId" />
    <label>Name</label><br />
    <input asp-for="Name" /><span asp-validation-for="Name" style="color:red"></span>
    <br /><br />
    <button type="submit">Save</button>
    <a asp-action="Index">Cancel</a>
</form>
