@model List<VolunteerHub.Mvc.Services.TotalByVolunteerRow>

@section Head {
    <style>
        .hint {
            color: #666;
            margin-bottom: 10px;
        }
    </style>
}

<h2>Report: Totals by Volunteer</h2>
<p class="hint">This report groups help records by volunteer and calculates total amount (LINQ GroupBy + Sum).</p>

<partial name="_DateFilter" />

<table>
    <thead>
        <tr>
            <th>Volunteer</th>
            <th>Records</th>
            <th>Total amount</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var row in Model)
        {
            <tr>
                <td>@row.VolunteerName</td>
                <td>@row.RecordsCount</td>
                <td><money value="@row.TotalAmount"></money></td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        console.log("TotalsByVolunteer loaded");
    </script>
}
