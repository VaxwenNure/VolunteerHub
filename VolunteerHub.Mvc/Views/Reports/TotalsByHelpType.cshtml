@using VolunteerHub.Mvc.Services
@model List<TotalByTypeRow>

<h2>Report: Totals by Help Type</h2>
<p class="description">This report groups help records by help type and calculates total amount.</p>

<form method="get">
    From: <input type="date" name="from" value="@ViewBag.From" />
    To: <input type="date" name="to" value="@ViewBag.To" />
    <button type="submit">Apply</button>
    <a asp-action="TotalsByHelpType">Reset</a>
</form>

<br />

<table>
    <thead>
        <tr>
            <th>Help type</th>
            <th>Records</th>
            <th>Total amount</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var row in Model)
        {
            <tr>
                <td>@row.HelpTypeName</td>
                <td>@row.RecordsCount</td>
                <td><b>@row.TotalAmount.ToString("N2") UAH</b></td>
            </tr>
        }
    </tbody>
</table>
