@using VolunteerHub.Mvc.Models.ViewModels
@model HelpRecordEditVm

<div>
    <label>Volunteer</label><br />
    <select asp-for="VolunteerId" asp-items="Model.Volunteers"></select>
    <br /><br />

    <label>Help type</label><br />
    <select asp-for="HelpTypeId" asp-items="Model.HelpTypes"></select>
    <br /><br />

    <label>Date</label><br />
    <input asp-for="HelpDate" type="date" />
    <br /><br />

    <label>Amount (UAH)</label><br />
    <input asp-for="Amount" />
    <br /><br />

    <label>Description</label><br />
    <input asp-for="Description" style="width:300px" />
    <br /><br />
</div>
