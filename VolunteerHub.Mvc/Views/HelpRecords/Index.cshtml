@using VolunteerHub.Data.Models
@model List<VolunteerHelp>

<h2>Help Records</h2>
<p class="add-button"><a asp-action="Create">Add new record</a></p>

<table>
    <thead>
        <tr>
            <th>Date</th>
            <th>Volunteer</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Description</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.HelpDate.ToString("yyyy-MM-dd")</td>
                <td>@r.Volunteer?.FullName</td>
                <td>@r.HelpType?.Name</td>
                <td>@r.Amount.ToString("N2") UAH</td>
                <td>@r.Description</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@r.VolunteerHelpId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@r.VolunteerHelpId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
