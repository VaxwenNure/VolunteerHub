@using VolunteerHub.Data.Models
@model VolunteerHelp

<h2>Delete Help Record</h2>

<p>Are you sure you want to delete this record?</p>
<ul>
    <li>Date: @Model.HelpDate.ToString("yyyy-MM-dd")</li>
    <li>Volunteer: @Model.Volunteer?.FullName</li>
    <li>Type: @Model.HelpType?.Name</li>
    <li>Amount: @Model.Amount.ToString("N2") UAH</li>
    <li>Description: @Model.Description</li>
</ul>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.VolunteerHelpId" />
    <button type="submit">Delete</button>
    <a asp-action="Index">Cancel</a>
</form>
