<Window x:Class="VolunteerHubUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Volunteer Hub" Height="600" Width="950"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="79*"/>
            <RowDefinition Height="62*"/>
        </Grid.RowDefinitions>
        <TabControl Grid.RowSpan="2">
            <!-- Volunteers -->
            <TabItem Header="Volunteers">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="VolunteersGrid" Grid.Column="0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding VolunteerId}" Width="60"/>
                            <DataGridTextColumn Header="Full name" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Full name"/>
                        <TextBox x:Name="VolunteerNameBox" Margin="0,4,0,10"/>

                        <TextBlock Text="Phone"/>
                        <TextBox x:Name="VolunteerPhoneBox" Margin="0,4,0,10"/>

                        <Button Content="Add" Click="AddVolunteer_Click" Margin="0,0,0,6"/>
                        <Button Content="Edit selected" Click="EditVolunteer_Click" Margin="0,0,0,6"/>
                        <Button Content="Delete selected" Click="DeleteVolunteer_Click" Margin="0,0,0,6"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Help Types -->
            <TabItem Header="Help Types">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="HelpTypesGrid" Grid.Column="0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding HelpTypeId}" Width="60"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Type name"/>
                        <TextBox x:Name="HelpTypeNameBox" Margin="0,4,0,10"/>

                        <Button Content="Add" Click="AddHelpType_Click" Margin="0,0,0,6"/>
                        <Button Content="Edit selected" Click="EditHelpType_Click" Margin="0,0,0,6"/>
                        <Button Content="Delete selected" Click="DeleteHelpType_Click" Margin="0,0,0,6"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Help Records (MAIN TABLE) -->
            <TabItem Header="Help Records">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="HelpGrid" Grid.Row="0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding VolunteerHelpId}" Width="60"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding HelpDate}" Width="140"/>
                            <DataGridTextColumn Header="Volunteer" Binding="{Binding Volunteer.FullName}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding HelpType.Name}" Width="160"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="100"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Volunteer"/>
                            <ComboBox x:Name="VolunteerCombo" DisplayMemberPath="FullName" SelectedValuePath="VolunteerId"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Help type"/>
                            <ComboBox x:Name="HelpTypeCombo" DisplayMemberPath="Name" SelectedValuePath="HelpTypeId"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                            <TextBlock Text="Amount"/>
                            <TextBox x:Name="AmountBox"/>
                            <TextBlock Text="Description" Margin="0,10,0,0"/>
                            <TextBox x:Name="DescriptionBox"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="10,0,0,0">
                            <TextBlock Text="Date"/>
                            <DatePicker x:Name="HelpDatePicker"/>
                            <Button Content="Add record" Click="AddHelpRecord_Click" Margin="0,10,0,6"/>
                            <Button Content="Edit selected" Click="EditHelpRecord_Click" Margin="0,0,0,6"/>
                            <Button Content="Delete selected" Click="DeleteHelpRecord_Click" Margin="0,0,0,6"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Reports -->
            <TabItem Header="Reports">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Content="Calculate totals by volunteer"
                            Click="TotalsByVolunteer_Click"
                            Width="260" Height="32"/>

                    <DataGrid x:Name="ReportGrid" Grid.Row="1" Margin="0,10,0,0"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
